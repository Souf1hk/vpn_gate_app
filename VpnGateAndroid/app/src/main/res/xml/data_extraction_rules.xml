<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude sensitive data from cloud backup -->
        <exclude domain="sharedpref" path="vpn_gate_prefs.xml"/>
        <exclude domain="database" />
        <exclude domain="file" path="openvpn/"/>
    </cloud-backup>
    <device-transfer>
        <!-- Allow device transfer but exclude sensitive data -->
        <exclude domain="sharedpref" path="vpn_gate_prefs.xml"/>
        <exclude domain="file" path="openvpn/"/>
    </device-transfer>
</data-extraction-rules>